{
  "name": "@specc/web",
  "private": true,
  "version": "0.0.0",
  "homepage": "https://phoenix5980.github.io/cindertide-studio-site",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "react-router build && rm -rf dist && mkdir -p dist && cp -R build/client/* dist/",
    "start": "node server.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format . --write",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist -r https://github.com/phoenix5980/cindertide-studio-site.git"
  },
  "dependencies": {
    "@react-router/fs-routes": "^7.13.1",
    "@react-router/node": "^7.13.1",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.12.0",
    "@trpc/react-query": "^11.12.0",
    "framer-motion": "^12.35.2",
    "i18next": "^25.8.17",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.6",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "gh-pages": "^6.3.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }
}
